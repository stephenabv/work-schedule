# Semaphore SMS API (https://semaphore.co) — used for class-reminder SMS.
# Get your key from the Semaphore dashboard. Set the real value in Vercel's
# project Environment Variables (Settings > Environment Variables), not here.
SEMAPHORE_API_KEY=

# Optional: a Semaphore-registered sender name. Defaults to "AzariSolar" if
# unset. The name must be registered AND approved on the Semaphore account,
# or Semaphore silently rejects the message.
SEMAPHORE_SENDER_NAME=

# Phone number(s) (PH format, e.g. 09171234567) that receive schedule
# reminders. One number, or several separated by commas:
# NOTIFY_PHONE_NUMBER=09171234567,09181234567
NOTIFY_PHONE_NUMBER=

# Optional but recommended: a random secret that authorizes calls to
# /api/notifications/cron. Vercel Cron sends this automatically as
# "Authorization: Bearer <CRON_SECRET>" once the env var is set. Without it,
# the cron endpoint accepts any request.
CRON_SECRET=
